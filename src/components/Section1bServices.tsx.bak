import React from 'react';
import { motion, AnimatePresence } from 'framer-motion';
import { Shield, Monitor, Fingerprint, Network, Code, ArrowUpRight, Terminal } from 'lucide-react';
import { TiltCard } from './ui/TiltCard';

/* ── Floating code particles for Software card ──────────── */
const CODE_SNIPPETS = ['<div/>', 'async', '=>', 'import', 'npm', '{...}', 'API', 'JSON', 'GET', 'POST', '[]', '()', '0x', 'SQL', '.tsx'];

const PARTICLES = Array.from({ length: 12 }, (_, i) => ({
  id: i,
  x: 5 + (i * 7.5),
  delay: i * 0.4,
  duration: 4 + (i % 4),
  snippet: CODE_SNIPPETS[i % CODE_SNIPPETS.length],
  size: i % 2 === 0 ? 'text-[11px]' : 'text-[9px]',
  opacity: 0.3 + (i % 3) * 0.15
}));

function SoftwareCard({ service }: { service: any }) {
  const [progress, setProgress] = React.useState(0);
  React.useEffect(() => {
    const t = setInterval(() => setProgress(p => p >= 100 ? 0 : p + 1), 60);
    return () => clearInterval(t);
  }, []);

  return (
    <TiltCard className="w-full h-full" intensity={20}>
      <div
        className="relative w-full h-full rounded-[2.5rem] overflow-hidden border border-emerald-500/20 hover:border-emerald-500/60 transition-all duration-700 hover:shadow-[0_0_60px_rgba(16,185,129,0.3)] group"
        style={{ transformStyle: 'preserve-3d', background: 'linear-gradient(145deg,#030f08,#020a05)' }}
      >
        {/* BG Image */}
        <div className="absolute inset-0 z-0">
          <img
            src={service.image}
            alt="Software"
            className="w-full h-full object-cover opacity-55 group-hover:opacity-75 group-hover:scale-105 transition-all duration-1000 ease-out"
          />
          <div className="absolute inset-0 bg-gradient-to-t from-[#010406] via-[#010406]/60 to-transparent" />
        </div>

        {/* Floating code particle bubbles drifting upward */}
        <div className="absolute inset-0 z-10 pointer-events-none overflow-hidden rounded-[2.5rem]">
          {PARTICLES.map(p => (
            <motion.span
              key={p.id}
              className={`absolute font-mono text-emerald-400 ${p.size}`}
              style={{ left: `${p.x}%`, bottom: '-5%', opacity: p.opacity }}
              animate={{ y: [0, -420], opacity: [p.opacity, p.opacity * 0.6, 0] }}
              transition={{ repeat: Infinity, duration: p.duration, delay: p.delay, ease: 'linear' }}
            >
              {p.snippet}
            </motion.span>
          ))}
        </div>

        {/* BUILD PROGRESS bar — top strip */}
        <div className="absolute top-4 left-5 right-5 z-20 flex flex-col gap-1.5">
          <div className="flex justify-between items-center">
            <span className="text-[10px] font-mono text-emerald-400 tracking-widest uppercase">▶ Building project…</span>
            <span className="text-[10px] font-mono text-emerald-400">{progress}%</span>
          </div>
          <div className="w-full h-1 bg-white/10 rounded-full overflow-hidden">
            <div
              className="h-full rounded-full shadow-[0_0_8px_rgba(16,185,129,0.8)]"
              style={{ width: `${progress}%`, background: 'linear-gradient(to right,#065f46,#10b981)' }}
            />
          </div>
        </div>

        {/* BUILD SUCCESS flash */}
        {progress === 0 && (
          <motion.div
            initial={{ opacity: 0, scale: 0.8 }}
            animate={{ opacity: [0, 1, 1, 0], scale: [0.8, 1, 1, 0.9] }}
            transition={{ duration: 1.5, times: [0, 0.15, 0.85, 1] }}
            className="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 z-30 px-6 py-2.5 rounded-xl bg-emerald-950/80 border border-emerald-500/60 text-emerald-400 font-bold text-sm tracking-widest backdrop-blur-md shadow-[0_0_30px_rgba(16,185,129,0.4)]"
          >
            ✓ BUILD SUCCESS
          </motion.div>
        )}

        {/* 3D content */}
        <div className="relative z-20 h-full flex flex-col justify-between p-10" style={{ transform: 'translateZ(40px)' }}>
          <div className="flex justify-between items-start mt-8" style={{ transform: 'translateZ(20px)' }}>
            <div className="w-16 h-16 rounded-3xl bg-black/50 border border-emerald-500/30 flex items-center justify-center backdrop-blur-xl group-hover:bg-emerald-500/20 group-hover:border-emerald-500/70 transition-all duration-500 shadow-2xl">
              {service.icon}
            </div>
            <div className="w-12 h-12 rounded-full bg-black/40 flex items-center justify-center border border-white/10 opacity-0 -translate-x-6 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-500">
              <ArrowUpRight className="w-6 h-6 text-emerald-400" />
            </div>
          </div>
          <div style={{ transform: 'translateZ(30px)' }}>
            <h3 className="text-4xl md:text-5xl font-bold text-white mb-4 group-hover:text-emerald-400 transition-colors duration-300 drop-shadow-xl">
              {service.title}
            </h3>
            <p className="text-gray-300 text-lg leading-relaxed font-light max-w-xl">{service.desc}</p>
          </div>
        </div>
      </div>
    </TiltCard>
  );
}
/* ─────────────────────────────────────────────────────────── */

/* ── Access Control biometric scan card ─────────────────── */
function AccessControlCard({ service }: { service: any }) {
  const [status, setStatus] = React.useState<'scanning'|'granted'|'denied'>('scanning');
  const now = new Date();
  const [clock, setClock] = React.useState(`${String(now.getHours()).padStart(2,'0')}:${String(now.getMinutes()).padStart(2,'0')}`);

  React.useEffect(() => {
    const tick = setInterval(() => {
      const d = new Date();
      setClock(`${String(d.getHours()).padStart(2,'0')}:${String(d.getMinutes()).padStart(2,'0')}`);
    }, 1000);
    return () => clearInterval(tick);
  }, []);

  React.useEffect(() => {
    const cycle = () => {
      setStatus('scanning');
      setTimeout(() => setStatus(Math.random() > 0.25 ? 'granted' : 'denied'), 2800);
      setTimeout(() => setStatus('scanning'), 5000);
    };
    cycle();
    const t = setInterval(cycle, 5200);
    return () => clearInterval(t);
  }, []);

  const isGranted = status === 'granted';
  const isDenied  = status === 'denied';
  const borderColor = isGranted ? 'border-emerald-500/70' : isDenied ? 'border-red-500/60' : 'border-amber-500/40';
  const glowColor  = isGranted ? '0_0_60px_rgba(16,185,129,0.45)' : isDenied ? '0_0_60px_rgba(239,68,68,0.4)' : '0_0_30px_rgba(245,158,11,0.2)';
  const ringColor  = isGranted ? '#10b981' : isDenied ? '#ef4444' : '#f59e0b';

  return (
    <TiltCard className="w-full h-full" intensity={20}>
      <div
        className={`relative w-full h-full rounded-[2.5rem] overflow-hidden border ${borderColor} transition-all duration-700 group`}
        style={{ transformStyle: 'preserve-3d', background: 'linear-gradient(145deg,#0a0800,#050400)', boxShadow: `0 0 0 rgba(0,0,0,0), inset 0 0 0 rgba(0,0,0,0)`, filter: `drop-shadow(${glowColor.replace(/_/g,' ')})` }}
      >
        {/* BG Image */}
        <div className="absolute inset-0 z-0">
          <img src={service.image} alt="Access Control" className="w-full h-full object-cover opacity-55 group-hover:opacity-75 group-hover:scale-105 transition-all duration-1000 ease-out" />
          <div className="absolute inset-0 bg-gradient-to-t from-[#010406] via-[#010406]/60 to-transparent" />
        </div>

        {/* Pulsing biometric scan rings — center */}
        <div className="absolute inset-0 z-10 pointer-events-none flex items-center justify-center">
          {[1,2,3].map(i => (
            <motion.div
              key={i}
              className="absolute rounded-full border"
              style={{ borderColor: ringColor, width: i * 55, height: i * 55, opacity: 0.6 / i }}
              animate={{ scale: [1, 1.4, 1], opacity: [0.6/i, 0, 0.6/i] }}
              transition={{ repeat: Infinity, duration: 2.2, delay: i * 0.4, ease: 'easeOut' }}
            />
          ))}
          {/* Fingerprint icon center */}
          <motion.div
            animate={{ opacity: [0.6, 1, 0.6] }}
            transition={{ repeat: Infinity, duration: 2 }}
            className="w-12 h-12 flex items-center justify-center rounded-full"
            style={{ background: `${ringColor}22`, border: `2px solid ${ringColor}` }}
          >
            <Fingerprint className="w-7 h-7" style={{ color: ringColor }} />
          </motion.div>
        </div>

        {/* Status badge */}
        <div className="absolute top-4 left-1/2 -translate-x-1/2 z-20">
          <motion.div
            key={status}
            initial={{ opacity: 0, y: -10, scale: 0.9 }}
            animate={{ opacity: 1, y: 0, scale: 1 }}
            className={`px-4 py-1.5 rounded-full text-[11px] font-bold tracking-widest uppercase border backdrop-blur-md ${
              isGranted ? 'bg-emerald-950/80 border-emerald-500/60 text-emerald-400' :
              isDenied  ? 'bg-red-950/80 border-red-500/60 text-red-400' :
                          'bg-amber-950/80 border-amber-500/40 text-amber-400'
            }`}
          >
            {isGranted ? '✓ ACCESS GRANTED' : isDenied ? '✕ ACCESS DENIED' : '◌ SCANNING…'}
          </motion.div>
        </div>

        {/* Live clock top-left */}
        <div className="absolute top-5 left-5 z-20 font-mono text-amber-400/70 text-xs tracking-widest">{clock}</div>

        {/* 3D content */}
        <div className="relative z-20 h-full flex flex-col justify-between p-8" style={{ transform: 'translateZ(40px)' }}>
          <div className="flex justify-end items-start mt-2" style={{ transform: 'translateZ(20px)' }}>
            <div className="w-12 h-12 rounded-full bg-black/40 flex items-center justify-center border border-white/10 opacity-0 -translate-x-4 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-500">
              <ArrowUpRight className="w-5 h-5" style={{ color: ringColor }} />
            </div>
          </div>
          <div style={{ transform: 'translateZ(30px)' }}>
            <h3 className="text-3xl font-bold text-white mb-3 drop-shadow-xl" style={{ color: isGranted ? '#10b981' : isDenied ? '#ef4444' : 'white', transition: 'color 0.5s' }}>
              {service.title}
            </h3>
            <p className="text-gray-300 text-base leading-relaxed font-light">{service.desc}</p>
          </div>
        </div>
      </div>
    </TiltCard>
  );
}
/* ─────────────────────────────────────────────────────────── */

/* ── Special CCTV live-feed card ───────────────────────── */
function CctvCard({ service }: { service: any }) {
  return (
    <TiltCard className="w-full h-full" intensity={20}>
      <div
        className="relative w-full h-full rounded-[2.5rem] overflow-hidden border border-[#00B4D8]/30 hover:border-[#00B4D8]/80 transition-all duration-700 hover:shadow-[0_0_60px_rgba(0,180,216,0.4)] group"
        style={{ transformStyle: 'preserve-3d', background: 'linear-gradient(145deg,#040e12,#020a0d)' }}
      >
        {/* BG Image */}
        <div className="absolute inset-0 z-0">
          <img
            src={service.image}
            alt="CCTV"
            className="w-full h-full object-cover opacity-60 group-hover:opacity-80 group-hover:scale-105 transition-all duration-1000 ease-out"
          />
          <div className="absolute inset-0 bg-gradient-to-t from-[#010406] via-[#010406]/50 to-transparent" />
        </div>

        {/* Corner brackets */}
        {(['top-3 left-3 border-t-2 border-l-2','top-3 right-3 border-t-2 border-r-2',
           'bottom-3 left-3 border-b-2 border-l-2','bottom-3 right-3 border-b-2 border-r-2'] as string[]).map((cls,i)=>(
          <div key={i} className={`absolute w-6 h-6 ${cls} border-[#00B4D8] z-20 opacity-70`} />
        ))}

        {/* REC blink */}
        <div className="absolute top-5 left-1/2 -translate-x-1/2 z-20 flex items-center gap-2">
          <motion.div
            animate={{ opacity: [1, 0, 1] }}
            transition={{ repeat: Infinity, duration: 1.2, ease: 'easeInOut' }}
            className="w-2.5 h-2.5 rounded-full bg-red-500 shadow-[0_0_8px_rgba(239,68,68,1)]"
          />
          <span className="text-[10px] text-red-400 font-bold tracking-[0.25em] uppercase">REC</span>
        </div>

        {/* Scan line */}
        <motion.div
          animate={{ y: ['-100%', '500%'] }}
          transition={{ repeat: Infinity, duration: 2.5, ease: 'linear' }}
          className="absolute left-0 w-full h-[8%] z-10 pointer-events-none"
          style={{ background: 'linear-gradient(to bottom, transparent, rgba(0,180,216,0.12), transparent)' }}
        />

        {/* Timestamp */}
        <div className="absolute top-5 left-5 z-20 text-[10px] text-[#00B4D8]/60 font-mono tracking-widest">
          CAM-01 · 24/7 LIVE
        </div>

        {/* 3D content */}
        <div className="relative z-10 h-full flex flex-col justify-between p-8" style={{ transform: 'translateZ(40px)' }}>
          <div className="flex justify-between items-start" style={{ transform: 'translateZ(20px)' }}>
            <div className="w-14 h-14 rounded-2xl bg-black/40 border border-[#00B4D8]/30 flex items-center justify-center backdrop-blur-xl group-hover:bg-[#00B4D8]/20 group-hover:border-[#00B4D8]/70 transition-all duration-500 shadow-2xl">
              {service.icon}
            </div>
            <div className="w-10 h-10 rounded-full bg-black/40 flex items-center justify-center border border-white/10 opacity-0 -translate-x-4 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-500">
              <ArrowUpRight className="w-5 h-5 text-[#00B4D8]" />
            </div>
          </div>

          <div style={{ transform: 'translateZ(30px)' }}>
            <h3 className="text-3xl font-bold text-white mb-3 group-hover:text-[#00B4D8] transition-colors duration-300 drop-shadow-xl">
              {service.title}
            </h3>
            <p className="text-gray-300 text-base leading-relaxed font-light">{service.desc}</p>
          </div>
        </div>
      </div>
    </TiltCard>
  );
}
/* ─────────────────────────────────────────────────────────── */

/* ── Digital Signage premium-display card ───────────────── */
const SIGN_SLIDES = [
  { 
    title: 'DYNAMIC DISPLAYS', 
    desc: 'High-impact visual communication.',
    color: 'from-blue-600/40 to-indigo-600/40',
  },
  { 
    title: 'SMART SOLUTIONS', 
    desc: 'Interactive retail & corporate tech.',
    color: 'from-purple-600/40 to-fuchsia-600/40',
  },
  { 
    title: 'CLOUD SIGNAGE', 
    desc: 'Manage content from anywhere.',
    color: 'from-emerald-600/40 to-teal-600/40',
  }
];

function DigitalSignageCard({ service }: { service: any }) {
  const [slide, setSlide] = React.useState(0);
  
  React.useEffect(() => {
    const timer = setInterval(() => setSlide(s => (s + 1) % SIGN_SLIDES.length), 5000);
    return () => clearInterval(timer);
  }, []);

  return (
    <TiltCard className="w-full h-full" intensity={15}>
      <div
        className="relative w-full h-full rounded-[2.5rem] overflow-hidden border border-violet-400/20 hover:border-violet-400/50 transition-all duration-1000 group shadow-2xl"
        style={{ transformStyle: 'preserve-3d', background: '#020106' }}
      >
        {/* BG Image - High Clarity */}
        <div className="absolute inset-0 z-0">
          <img 
            src={service.image} 
            alt="Digital Signage" 
            className="w-full h-full object-cover opacity-65 group-hover:opacity-85 group-hover:scale-105 transition-all duration-1000 ease-out" 
          />
          {/* Subtle vignette for depth without hiding the image */}
          <div className="absolute inset-0 bg-gradient-to-t from-[#010406] via-transparent to-transparent opacity-60" />
        </div>

        {/* Premium Floating Screen - Subtle & Clean */}
        <div className="absolute inset-0 z-10 flex items-center justify-center pointer-events-none p-14">
          <div className="relative w-full aspect-video rounded-2xl border border-white/30 bg-white/5 backdrop-blur-md shadow-[0_30px_70px_rgba(0,0,0,0.6)] overflow-hidden" 
               style={{ transform: 'perspective(1200px) rotateX(8deg) translateZ(25px)' }}>
            
            {/* Screen Reflection Overlay */}
            <div className="absolute inset-0 bg-gradient-to-tr from-white/10 via-transparent to-white/5 z-20" />
            
            <AnimatePresence mode="wait">
              <motion.div
                key={slide}
                initial={{ opacity: 0, scale: 1.05 }}
                animate={{ opacity: 1, scale: 1 }}
                exit={{ opacity: 0, scale: 0.95 }}
                transition={{ duration: 1.2, ease: [0.4, 0, 0.2, 1] }}
                className={`absolute inset-0 flex flex-col justify-center items-center text-center p-6 bg-gradient-to-br ${SIGN_SLIDES[slide].color} opacity-80`}
              >
                <motion.h4 
                  className="text-white font-bold text-xl md:text-2xl tracking-tight mb-2 drop-shadow-md"
                >
                  {SIGN_SLIDES[slide].title}
                </motion.h4>
                <p className="text-white/80 text-[11px] font-medium tracking-wide uppercase">
                  {SIGN_SLIDES[slide].desc}
                </p>
                
                {/* Minimal Activity Dots */}
                <div className="mt-4 flex gap-1.5">
                  {SIGN_SLIDES.map((_, i) => (
                    <div key={i} className={`w-1 h-1 rounded-full transition-all duration-500 ${i === slide ? 'bg-white scale-150' : 'bg-white/30'}`} />
                  ))}
                </div>
              </motion.div>
            </AnimatePresence>

            {/* Subtle Glint Sweep */}
            <motion.div 
              animate={{ x: ['-200%', '200%'] }}
              transition={{ repeat: Infinity, duration: 6, ease: "linear" }}
              className="absolute inset-0 z-30 bg-gradient-to-r from-transparent via-white/10 to-transparent skew-x-12"
            />
          </div>
        </div>

        {/* Minimal UI Overlay */}
        <div className="relative z-20 h-full flex flex-col justify-between p-10" style={{ transform: 'translateZ(60px)' }}>
          <div className="flex justify-between items-start">
            <div className="w-14 h-14 rounded-2xl bg-black/50 border border-violet-400/30 flex items-center justify-center backdrop-blur-xl group-hover:border-violet-400/60 transition-all duration-500 shadow-xl">
              {service.icon}
            </div>
            <div className="flex items-center gap-2 bg-black/40 backdrop-blur-md px-3 py-1 rounded-full border border-violet-400/30">
              <motion.div 
                animate={{ opacity: [0.4, 1, 0.4] }}
                transition={{ repeat: Infinity, duration: 2 }}
                className="w-1.5 h-1.5 rounded-full bg-violet-400 shadow-[0_0_8px_#a78bfa]"
              />
              <span className="text-[9px] font-bold text-violet-300 tracking-widest uppercase">STREAMING</span>
            </div>
          </div>
          
          <div style={{ transform: 'translateZ(40px)' }}>
            <h3 className="text-4xl md:text-5xl font-bold text-white mb-4 group-hover:text-violet-400 transition-colors duration-500 drop-shadow-2xl">
              {service.title}
            </h3>
            <p className="text-gray-300 text-lg leading-relaxed font-light max-w-md group-hover:text-white transition-colors duration-500">
              {service.desc}
            </p>
          </div>
        </div>
      </div>
    </TiltCard>
  );
}
