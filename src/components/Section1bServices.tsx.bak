/* ── Structured Cabling data-flow card ──────────────────── */
const NETWORK_NODES = Array.from({ length: 15 }, (_, i) => ({
  id: i,
  x: Math.random() * 80 + 10,
  y: Math.random() * 80 + 10,
  delay: Math.random() * 5,
  duration: 3 + Math.random() * 3
}));

function StructuredCablingCard({ service }: { service: any }) {
  return (
    <TiltCard className="w-full h-full" intensity={20}>
      <div
        className="relative w-full h-full rounded-[2.5rem] overflow-hidden border border-sky-400/20 hover:border-sky-400/60 transition-all duration-1000 group shadow-[0_0_40px_rgba(0,0,0,0.5)]"
        style={{ transformStyle: 'preserve-3d', background: '#020408' }}
      >
        {/* BG Image - High Clarity */}
        <div className="absolute inset-0 z-0">
          <img 
            src={service.image} 
            alt="Structured Cabling" 
            className="w-full h-full object-cover opacity-60 group-hover:opacity-85 group-hover:scale-105 transition-all duration-1000 ease-out" 
          />
          <div className="absolute inset-0 bg-gradient-to-t from-[#010406] via-transparent to-transparent opacity-80" />
        </div>

        {/* Circuit/Data Flow Overlay */}
        <div className="absolute inset-0 z-10 pointer-events-none">
          <svg className="w-full h-full">
            {NETWORK_NODES.slice(0, 10).map((node, i) => (
              <React.Fragment key={i}>
                <motion.path
                  d={`M ${node.x} ${node.y} L ${node.x + 40} ${node.y + 40}`}
                  stroke="rgba(56, 189, 248, 0.2)"
                  strokeWidth="0.5"
                  fill="none"
                />
                <motion.circle
                  r="1.5"
                  fill="#38bdf8"
                  initial={{ offsetDistance: "0%" }}
                  animate={{ offsetDistance: "100%" }}
                  transition={{ repeat: Infinity, duration: 3 + Math.random() * 2, delay: i * 0.4, ease: "linear" }}
                  style={{ 
                    offsetPath: `path('M ${node.x * 5} ${node.y * 5} L ${(node.x + 20) * 5} ${(node.y + 20) * 5}')`,
                    filter: 'drop-shadow(0 0 8px #38bdf8)'
                  }}
                />
              </React.Fragment>
            ))}
          </svg>
        </div>

        {/* Content */}
        <div className="relative z-20 h-full flex flex-col justify-between p-10" style={{ transform: 'translateZ(80px)' }}>
          <div className="flex justify-between items-start" style={{ transform: 'translateZ(40px)' }}>
            <div className="w-16 h-16 rounded-3xl bg-black/60 border border-sky-400/30 flex items-center justify-center backdrop-blur-xl group-hover:bg-sky-400/20 group-hover:border-sky-400/70 transition-all duration-500 shadow-2xl">
              {service.icon}
            </div>
            <div className="flex flex-col items-end gap-1">
              <div className="flex items-center gap-2">
                <motion.div animate={{ opacity: [0.3, 1, 0.3] }} transition={{ repeat: Infinity, duration: 1.5 }} className="w-2 h-2 rounded-full bg-sky-400 shadow-[0_0_10px_#38bdf8]" />
                <span className="text-[10px] font-bold text-sky-300 tracking-[0.2em] uppercase">LINK ACTIVE</span>
              </div>
              <div className="text-[8px] font-mono text-sky-400/60 uppercase">10Gbps Dedicated</div>
            </div>
          </div>
          <div style={{ transform: 'translateZ(60px)' }}>
            <h3 className="text-4xl md:text-5xl font-bold text-white mb-4 group-hover:text-sky-300 transition-colors duration-500">{service.title}</h3>
            <p className="text-gray-200 text-lg leading-relaxed font-light max-w-md">{service.desc}</p>
          </div>
        </div>
      </div>
    </TiltCard>
  );
}

/* ─────────────────────────────────────────────────────────── */

